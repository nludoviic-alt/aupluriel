# ── Variables d'environnement (à définir dans Railway, PAS dans le code) ──
# Copie ce fichier en .env pour le dev local. NE COMMITE JAMAIS le vrai .env.

# Secret de signature des tokens de connexion (JWT). OBLIGATOIRE en production.
# Génère-en un avec :  openssl rand -hex 32
JWT_SECRET=change-me-with-a-long-random-value

# Emplacement du fichier de base de données SQLite.
# En production sur Railway, pointe vers le volume persistant (ex. /data/lio23.db).
DB_PATH=/data/lio23.db

# Code d'invitation pour l'inscription (optionnel).
# Si défini, seuls ceux qui connaissent ce code peuvent créer un compte.
# Laisse vide / non défini pour une inscription ouverte.
INVITE_CODE=

# Node : Railway le met automatiquement à "production".
# NODE_ENV=production
