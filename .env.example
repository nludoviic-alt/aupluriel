# ── Variables d'environnement (à définir dans Railway, PAS dans le code) ──
# Copie ce fichier en .env pour le dev local. NE COMMITE JAMAIS le vrai .env.

# Secret de signature des tokens de connexion (JWT). OBLIGATOIRE en production.
# Génère-en un avec :  openssl rand -hex 32
JWT_SECRET=change-me-with-a-long-random-value

# Emplacement du fichier de base de données SQLite.
# En production sur Railway, pointe vers le volume persistant (ex. /data/lio23.db).
DB_PATH=/data/lio23.db

# Code d'invitation pour l'inscription (optionnel).
# Si défini, seuls ceux qui connaissent ce code peuvent créer un compte.
# Laisse vide / non défini pour une inscription ouverte.
INVITE_CODE=

# Email de l'administrateur. Ce compte est auto-vérifié + auto-approuvé à
# l'inscription, contourne le code d'invitation et accède au panneau /admin.
ADMIN_EMAIL=

# URL publique de l'app, utilisée pour construire les liens dans les emails
# (vérification, reset). Ex: https://lio23-vortex-production.up.railway.app
APP_URL=

# ── Envoi d'emails (vérification + reset de mot de passe) via Resend ──
# Crée un compte sur https://resend.com, génère une clé API et colle-la ici.
# Sans clé, les emails ne sont PAS envoyés mais sont logués dans la console serveur.
RESEND_API_KEY=
# Adresse d'expéditeur. Doit appartenir à un domaine vérifié dans Resend pour
# envoyer à n'importe qui. Par défaut: "LIO23 <onboarding@resend.dev>" (test only).
EMAIL_FROM=

# ── Assistant IA (chat) ──
# Clé serveur qui fait fonctionner le chat pour TOUS les utilisateurs (sinon
# chacun doit mettre sa propre clé dans Paramètres → Assistant IA).
# Anthropic (par défaut, modèle claude-haiku-4-5) : https://console.anthropic.com
ANTHROPIC_API_KEY=
# Alternative OpenAI (gpt-4o-mini) : https://platform.openai.com
OPENAI_API_KEY=

# Node : Railway le met automatiquement à "production".
# NODE_ENV=production
